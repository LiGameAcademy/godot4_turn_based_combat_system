[resource]
script = ExtResource("1_p4oqj")
character_name = "格罗姆尼尔"
description = "来自地底深城的坚毅矮人，他的战锤能粉碎岩石，他的意志如水晶般坚不可摧。作为团队的先锋，他总是站在最前线，为同伴筑起一道可靠的屏障。"
